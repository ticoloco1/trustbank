# Copie para .env.local e preencha. No Vercel: Settings → Environment Variables.
# Obrigatória para o app funcionar:

DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# Sessão login próprio (obrigatório em produção)
SESSION_SECRET="uma-string-longa-aleatoria-em-producao"

# Admin: sua wallet para acessar o painel (uma ou várias separadas por vírgula)
ADMIN_WALLET="0x..."
# ADMIN_WALLETS="0x...,0x..."

# Opcionais (o app tem valores padrão):
# NEXT_PUBLIC_APP_URL="https://trustbank.xyz"
# NEXT_PUBLIC_USE_PRISMA="true"
# NEXT_PUBLIC_SITE="trustbank"

# Pagamentos / blockchain (opcional; usa contrato e treasury padrão se vazio)
# PLATFORM_WALLET="0x..."
# PLATFORM_WALLET_PRIVATE_KEY="0x..."   # só para saques automáticos USDC
# CHAIN_RPC_URL="https://eth.llamarpc.com"
# POLYGON_RPC_URL="https://polygon-rpc.com"
# ETH_RPC_URL="https://eth.llamarpc.com"
# USDC_ETH_CONTRACT="0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48"
# USDC_POLYGON_CONTRACT="0x3c499c542cEF5E3811e1192ce70d8cC03d5c3359"

# Stripe (cartão → USDC)
# STRIPE_SECRET_KEY="sk_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."

# Google / YouTube (login e paywall; ou configure no painel admin)
# GOOGLE_CLIENT_ID="..."
# GOOGLE_CLIENT_SECRET="..."
# YOUTUBE_API_KEY="..."
# GOOGLE_API_KEY="..."

# Cron / prerender (opcional)
# CRON_SECRET="..."

# Upload de imagens (Vercel Blob)
# BLOB_READ_WRITE_TOKEN="..."

# Paywall (opcional)
# REQUIRE_PAYWALL_TX="true"

# Supabase (se usar auth/backend Supabase em vez de Prisma)
# NEXT_PUBLIC_SUPABASE_URL="https://seu-projeto.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
